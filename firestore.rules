rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() { return request.auth != null; }
    function isOwner(uid) { return request.auth.uid == uid; }
    function isAdmin() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    function validFarmerData() {
      return request.resource.data.keys().hasAll(['displayName']) &&
             request.resource.data.displayName is string &&
             request.resource.data.displayName.size() <= 100;
    }

    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid);
      allow delete: if isAdmin();
    }

    match /diseaseHistory/{uid}/records/{recordId} {
      allow read, write: if isOwner(uid);
      allow read: if isAdmin();
    }

    match /notifications/{uid}/items/{notifId} {
      allow read, write: if isOwner(uid);
    }

    match /chatSessions/{uid}/sessions/{sessionId} {
      allow read, write: if isOwner(uid);
    }

    match /chatSessions/{uid}/sessions/{sessionId}/messages/{messageId} {
      allow read, write: if isOwner(uid);
    }

    match /trainingFeedback/{docId} {
      allow create: if isAuth();
      allow read, write: if isAdmin();
    }

    match /fertilizerRules/{document=**} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    match /adminConfig/{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
